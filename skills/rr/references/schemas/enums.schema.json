{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "enums.schema.json",
  "title": "RR Skill Enumerations",
  "description": "Shared enums for all RR skill artifacts. All values are STRICT — reject non-conforming values.",

  "definitions": {
    "likelihood": {
      "type": "string",
      "enum": ["Low", "Medium", "High"],
      "description": "Probability of risk materialising"
    },

    "impact": {
      "type": "string",
      "enum": ["Low", "Medium", "High"],
      "description": "Severity if risk materialises"
    },

    "risk_rating": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Critical"],
      "description": "Combined rating derived from likelihood × impact matrix"
    },

    "risk_category": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "ER", "F", "I", "L", "O", "OO", "P", "T"],
      "description": "Risk category prefix from the register",
      "enumDescriptions": {
        "A": "Audit",
        "B": "Business Continuity Management",
        "C": "Compliance",
        "D": "Product / Design",
        "ER": "Expansion Risk",
        "F": "Financial",
        "I": "Investment",
        "L": "Legal",
        "O": "Operational",
        "OO": "Other Operational",
        "P": "People",
        "T": "Technology"
      }
    },

    "control_type": {
      "type": "string",
      "enum": ["Preventive", "Detective", "Corrective"],
      "description": "Nature of the control mechanism"
    },

    "control_effectiveness": {
      "type": "string",
      "enum": ["Effective", "Partially Effective", "Ineffective", "Uncertain"],
      "description": "Assessed effectiveness of the control"
    },

    "assessment_status": {
      "type": "string",
      "enum": ["draft", "adversarial_reviewed", "rectified", "final"],
      "description": "Stage of the assessment in the workflow"
    },

    "assessment_iteration": {
      "type": "integer",
      "enum": [1, 2, 3],
      "description": "Assessment version: 1=draft, 2=rectified, 3=final"
    },

    "challenge_type": {
      "type": "string",
      "enum": [
        "unsupported_claim",
        "speculative_assertion",
        "outdated_reference",
        "missing_evidence",
        "unbounded_scope",
        "rating_not_justified",
        "control_assumed",
        "regulatory_imprecision",
        "logical_inconsistency"
      ],
      "description": "Type of adversarial challenge raised"
    },

    "regulatory_status": {
      "type": "string",
      "enum": ["active", "superseded", "under_consultation", "proposed"],
      "description": "Current status of a regulatory instrument"
    },

    "jurisdiction": {
      "type": "string",
      "enum": ["SG", "HK", "UAE", "JP", "GLOBAL"],
      "description": "Regulatory jurisdiction"
    },

    "iso8601_date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date in YYYY-MM-DD format"
    },

    "ticket_key": {
      "type": "string",
      "pattern": "^RR-\\d+$",
      "description": "Jira ticket key in RR-NNN format"
    },

    "suggested_owner": {
      "type": "string",
      "enum": ["CEO", "CTO", "CFO", "COO", "Head of Compliance", "Head of Risk"],
      "description": "Role to suggest as owner for recommendations. Use CTO, never 'Head of Technology'."
    }
  },

  "rating_matrix": {
    "description": "Likelihood × Impact → Rating derivation rules",
    "rules": [
      { "likelihood": "High", "impact": "High", "rating": "Critical" },
      { "likelihood": "High", "impact": "Medium", "rating": "High" },
      { "likelihood": "High", "impact": "Low", "rating": "Medium" },
      { "likelihood": "Medium", "impact": "High", "rating": "High" },
      { "likelihood": "Medium", "impact": "Medium", "rating": "Medium" },
      { "likelihood": "Medium", "impact": "Low", "rating": "Low" },
      { "likelihood": "Low", "impact": "High", "rating": "Medium" },
      { "likelihood": "Low", "impact": "Medium", "rating": "Low" },
      { "likelihood": "Low", "impact": "Low", "rating": "Low" }
    ]
  }
}
