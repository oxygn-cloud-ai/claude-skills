{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "discussion.schema.json",
  "title": "Assessment Discussion",
  "description": "Structured log of user discussion during Step 4. Updated incrementally.",

  "type": "object",
  "required": ["metadata", "unresolved_points", "exchanges", "status"],
  "additionalProperties": false,

  "properties": {
    "metadata": {
      "type": "object",
      "required": ["ticket_key", "discussion_date", "source_assessment"],
      "properties": {
        "ticket_key": { "$ref": "enums.schema.json#/definitions/ticket_key" },
        "discussion_date": { "$ref": "enums.schema.json#/definitions/iso8601_date" },
        "source_assessment": { 
          "type": "string",
          "description": "Filename of Assessment 2 being discussed"
        },
        "started_at": { "type": "string", "format": "time" },
        "completed_at": { "type": ["string", "null"], "format": "time" }
      }
    },

    "unresolved_points": {
      "type": "array",
      "description": "Points identified at start of discussion that require resolution",
      "items": {
        "type": "object",
        "required": ["id", "point_type", "description", "status"],
        "properties": {
          "id": { 
            "type": "string", 
            "pattern": "^UP\\d{3}$",
            "description": "Unresolved point ID in format UP001, UP002, etc."
          },
          "point_type": {
            "type": "string",
            "enum": [
              "internal_fact_unknown",
              "control_effectiveness_uncertain",
              "data_quality_issue",
              "judgment_based_rating",
              "regulatory_verification_needed"
            ]
          },
          "section": {
            "type": "string",
            "enum": [
              "context",
              "regulatory_framework",
              "inherent_risk",
              "existing_controls",
              "residual_risk",
              "recommendations",
              "evidences"
            ]
          },
          "description": { "type": "string" },
          "question_posed": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "resolved", "deferred", "user_declined"]
          },
          "resolution": { "type": ["string", "null"] },
          "assessment_impact": { 
            "type": ["string", "null"],
            "description": "How the resolution affects the assessment"
          }
        }
      }
    },

    "exchanges": {
      "type": "array",
      "description": "Chronological log of Q&A exchanges",
      "items": {
        "type": "object",
        "required": ["id", "timestamp", "exchange_type"],
        "properties": {
          "id": { 
            "type": "string", 
            "pattern": "^EX\\d{3}$",
            "description": "Exchange ID in format EX001, EX002, etc."
          },
          "timestamp": { "type": "string", "format": "time" },
          "exchange_type": {
            "type": "string",
            "enum": ["question_to_user", "user_response", "follow_up", "user_initiated", "clarification"]
          },
          "related_point_id": { 
            "type": ["string", "null"],
            "description": "ID of the unresolved point this exchange relates to"
          },
          "content": { "type": "string" },
          "speaker": {
            "type": "string",
            "enum": ["claude", "user"]
          },
          "triggers_web_search": { "type": "boolean" },
          "web_search_result_summary": { "type": ["string", "null"] },
          "assessment_change_triggered": {
            "type": ["object", "null"],
            "properties": {
              "section": { "type": "string" },
              "change_type": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },

    "user_challenges": {
      "type": "array",
      "description": "Challenges or disagreements raised by the user",
      "items": {
        "type": "object",
        "required": ["id", "challenge", "response", "outcome"],
        "properties": {
          "id": { 
            "type": "string", 
            "pattern": "^UC\\d{3}$",
            "description": "User challenge ID in format UC001, UC002, etc."
          },
          "challenge": { "type": "string" },
          "related_section": { "type": "string" },
          "response": { "type": "string" },
          "outcome": {
            "type": "string",
            "enum": ["accepted_change", "rejected_with_justification", "partially_accepted", "deferred"]
          },
          "assessment_change": { "type": ["string", "null"] }
        }
      }
    },

    "status": {
      "type": "object",
      "required": ["total_unresolved", "resolved_count", "pending_count", "discussion_complete"],
      "properties": {
        "total_unresolved": { "type": "integer", "minimum": 0 },
        "resolved_count": { "type": "integer", "minimum": 0 },
        "pending_count": { "type": "integer", "minimum": 0 },
        "deferred_count": { "type": "integer", "minimum": 0 },
        "user_challenges_count": { "type": "integer", "minimum": 0 },
        "discussion_complete": { "type": "boolean" },
        "completion_reason": {
          "type": ["string", "null"],
          "enum": ["all_points_resolved", "user_requested_progression", "deferred_to_risk_owner", null]
        }
      }
    }
  }
}
